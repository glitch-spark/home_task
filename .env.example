# =============================================================================
# Local development (copy to .env.local)
# =============================================================================
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/home_task"

# Server-only — never prefix with NEXT_PUBLIC_ or commit real keys
OPENAI_API_KEY="sk-your-key-here"

# =============================================================================
# Render production (set in Render Dashboard → Environment)
# =============================================================================
# DATABASE_URL  → Auto-injected when you link the Render PostgreSQL instance
#                 (Internal Database URL). Do not commit production URLs.
# OPENAI_API_KEY → Add manually as a Secret; required for AI review.
# NODE_ENV=production (set by render.yaml)
